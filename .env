# Base de datos - CONFIGURACIÓN LOCAL
DB_HOST=localhost
DB_NAME=travelag_travel_agency
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Aplicación - CONFIGURACIÓN LOCAL
APP_NAME=Travel Agency
APP_URL=http://travelagency.local
APP_ENV=development
APP_DEBUG=true

# Google Translate (opcional)
GOOGLE_TRANSLATE_API_KEY=

# Mapbox (opcional)
MAPBOX_ACCESS_TOKEN=

# Seguridad
SESSION_LIFETIME=3600
CSRF_TOKEN_NAME=_token

# Configuración de uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=/assets/uploads/

# Configuración de email (opcional)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls